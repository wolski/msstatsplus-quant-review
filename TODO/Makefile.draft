# =============================================================================
# 4. REVIEW
# =============================================================================
review: review-html review-pdf

# review.qmd reads model CSVs from every cell-block, so depends on all cell
# stamps. KNOWN ISSUE: some cells fail upstream (e.g. MSstats+ × quantile
# subsets — Bioc dataProcess bug). If a stamp is permanently missing,
# `make review` will block. Two workarounds:
#   (a) run `make -k review` (--keep-going) to attempt review.qmd anyway;
#       review.qmd guards each chunk with file.exists() and skips missing models.
#   (b) for cells you've confirmed are known-broken, manually create the
#       stamp: `touch <missing>/.stamp`. Documents that you accept the gap.
REVIEW_DEPS = vignettes/review.qmd \
    CSF_Spectronaut/all_data/log2/swap/.stamp                            CSF_Spectronaut/good_data/log2/swap/.stamp \
    CSF_Spectronaut_sample_swap/all_data/log2/swap/.stamp                CSF_Spectronaut_sample_swap/all_data/median/swap/.stamp                CSF_Spectronaut_sample_swap/all_data/quantile/swap/.stamp \
    CSF_Spectronaut_sample_swap/good_data/log2/swap/.stamp               CSF_Spectronaut_sample_swap/good_data/median/swap/.stamp               CSF_Spectronaut_sample_swap/good_data/quantile/swap/.stamp \
    CSF_Spectronaut_sample_swap/small_good_data/log2/swap/.stamp         CSF_Spectronaut_sample_swap/small_good_data/median/swap/.stamp         CSF_Spectronaut_sample_swap/small_good_data/quantile/swap/.stamp \
    CSF_Spectronaut_protein_swap/all_data/log2/swap/.stamp               CSF_Spectronaut_protein_swap/all_data/median/swap/.stamp               CSF_Spectronaut_protein_swap/all_data/quantile/swap/.stamp \
    CSF_Spectronaut_protein_swap/good_data/log2/swap/.stamp              CSF_Spectronaut_protein_swap/good_data/median/swap/.stamp              CSF_Spectronaut_protein_swap/good_data/quantile/swap/.stamp \
    CSF_Spectronaut_protein_swap/small/log2/swap/.stamp                  CSF_Spectronaut_protein_swap/small/median/swap/.stamp                  CSF_Spectronaut_protein_swap/small/quantile/swap/.stamp \
    CSF_Spectronaut_protein_swap/small_good_data/log2/swap/.stamp        CSF_Spectronaut_protein_swap/small_good_data/median/swap/.stamp        CSF_Spectronaut_protein_swap/small_good_data/quantile/swap/.stamp \
    Mix_of_Proteome/all_data/log2/swap/.stamp                            Mix_of_Proteome/all_data/median/swap/.stamp                            Mix_of_Proteome/all_data/quantile/swap/.stamp

review-html: $(REVIEW_DEPS)
	cd vignettes && quarto render review.qmd --to html

review-pdf: $(REVIEW_DEPS)
	cd vignettes && quarto render review.qmd --to pdf

# review-best-effort: render review.qmd against whatever cell outputs happen
# to exist on disk. Use when you've already accepted that certain cells are
# expected to be missing (e.g. MSstats+ × quantile, DEqMS × small × log2).
# Does NOT touch stamp files — the DAG still records those cells as missing
# so the strict `make review` will continue to flag them. review.qmd guards
# each chunk with file.exists() and skips models that aren't on disk.
review-best-effort: vignettes/review.qmd
	cd vignettes && quarto render review.qmd --to html
	cd vignettes && quarto render review.qmd --to pdf


# =============================================================================
# 5. CLEAN — layered. `make clean` is a NO-OP (deliberate). Pick the level:
#
#   clean-models   - remove every <subset>/<norm>/swap/ tree (model CSVs +
#                    diagnostics HTML + .stamp). Regen with: make cells diagnostics.
#                    ~hours per cell-block to rebuild.
#
#   clean-subsets  - also remove every <subset>/ dir (subset Report.tsv +
#                    annotation.csv) and the .prep.stamp files. Regen with:
#                    make prep cells diagnostics. Seconds for prep, then ~hours.
#
#   clean-prep     - also remove swap-script outputs at folder root for the
#                    two swap folders. Keeps the symlinks in CSF_Spectronaut/
#                    and Mix_of_Proteome/.
#
# The original Spectronaut TSVs and original annotations are NEVER touched.
# =============================================================================
clean:
	@echo "No-op. Use:"
	@echo "  make clean-models   - remove model CSVs + diagnostics HTMLs + stamps"
	@echo "  make clean-subsets  - also remove subset Report.tsv + annotation.csv + prep stamps"
	@echo "  make clean-prep     - also remove swap-script outputs at folder root"
	@echo "Original Spectronaut TSVs and annotations are NEVER touched."

clean-models:
	rm -rf CSF_Spectronaut/all_data/log2/swap
	rm -rf CSF_Spectronaut/good_data/log2/swap
	rm -rf CSF_Spectronaut_sample_swap/all_data/log2/swap
	rm -rf CSF_Spectronaut_sample_swap/all_data/median/swap
	rm -rf CSF_Spectronaut_sample_swap/all_data/quantile/swap
	rm -rf CSF_Spectronaut_sample_swap/good_data/log2/swap
	rm -rf CSF_Spectronaut_sample_swap/good_data/median/swap
	rm -rf CSF_Spectronaut_sample_swap/good_data/quantile/swap
	rm -rf CSF_Spectronaut_sample_swap/small_good_data/log2/swap
	rm -rf CSF_Spectronaut_sample_swap/small_good_data/median/swap
	rm -rf CSF_Spectronaut_sample_swap/small_good_data/quantile/swap
	rm -rf CSF_Spectronaut_protein_swap/all_data/log2/swap
	rm -rf CSF_Spectronaut_protein_swap/all_data/median/swap
	rm -rf CSF_Spectronaut_protein_swap/all_data/quantile/swap
	rm -rf CSF_Spectronaut_protein_swap/good_data/log2/swap
	rm -rf CSF_Spectronaut_protein_swap/good_data/median/swap
	rm -rf CSF_Spectronaut_protein_swap/good_data/quantile/swap
	rm -rf CSF_Spectronaut_protein_swap/small/log2/swap
	rm -rf CSF_Spectronaut_protein_swap/small/median/swap
	rm -rf CSF_Spectronaut_protein_swap/small/quantile/swap
	rm -rf CSF_Spectronaut_protein_swap/small_good_data/log2/swap
	rm -rf CSF_Spectronaut_protein_swap/small_good_data/median/swap
	rm -rf CSF_Spectronaut_protein_swap/small_good_data/quantile/swap
	rm -rf Mix_of_Proteome/all_data/log2/swap
	rm -rf Mix_of_Proteome/all_data/median/swap
	rm -rf Mix_of_Proteome/all_data/quantile/swap

clean-subsets: clean-models
	rm -rf CSF_Spectronaut/all_data
	rm -rf CSF_Spectronaut/good_data
	rm -rf CSF_Spectronaut_sample_swap/all_data
	rm -rf CSF_Spectronaut_sample_swap/good_data
	rm -rf CSF_Spectronaut_sample_swap/small_good_data
	rm -rf CSF_Spectronaut_protein_swap/all_data
	rm -rf CSF_Spectronaut_protein_swap/good_data
	rm -rf CSF_Spectronaut_protein_swap/small
	rm -rf CSF_Spectronaut_protein_swap/small_good_data
	rm -rf Mix_of_Proteome/all_data
	rm -f  CSF_Spectronaut/.prep.stamp
	rm -f  CSF_Spectronaut_sample_swap/.prep.stamp
	rm -f  CSF_Spectronaut_protein_swap/.prep.stamp
	rm -f  Mix_of_Proteome/.prep.stamp

clean-prep: clean-subsets
	rm -f CSF_Spectronaut_sample_swap/Report.tsv
	rm -f CSF_Spectronaut_sample_swap/annotation.csv
	rm -f CSF_Spectronaut_sample_swap/CSF_protein_swap_list.csv
	rm -f CSF_Spectronaut_sample_swap/*_sample_swap.tsv
	rm -f CSF_Spectronaut_sample_swap/*_sample_swap_ground_truth.tsv
	rm -f CSF_Spectronaut_sample_swap/*_sample_swap_group_annotation.csv
	rm -f CSF_Spectronaut_sample_swap/*_sample_swap_true_positives.tsv
	rm -f CSF_Spectronaut_protein_swap/Report.tsv
	rm -f CSF_Spectronaut_protein_swap/annotation.csv
	rm -f CSF_Spectronaut_protein_swap/CSF_protein_swap_list.csv
	rm -f CSF_Spectronaut_protein_swap/*_swap_ground_truth.tsv
	rm -f CSF_Spectronaut_protein_swap/*_swap_group_annotation.csv
	rm -f CSF_Spectronaut_protein_swap/*_swap_true_positives.tsv
