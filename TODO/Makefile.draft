	Rscript R/run_nonmsstats_block.R Mix_of_Proteome/all_data quantile
	touch $@


# =============================================================================
# 3. DIAGNOSTICS — one diagnostics.html per cell-block. Depends on cells stamp.
# =============================================================================
diagnostics: diag-csf diag-sample-swap diag-protein-swap diag-mix

# --- CSF_Spectronaut diagnostics ---------------------------------------------
diag-csf: diag-csf-all_data-log2 diag-csf-good_data-log2

diag-csf-all_data-log2:  CSF_Spectronaut/all_data/log2/swap/diagnostics.html
diag-csf-good_data-log2: CSF_Spectronaut/good_data/log2/swap/diagnostics.html

CSF_Spectronaut/all_data/log2/swap/diagnostics.html: CSF_Spectronaut/all_data/log2/swap/.stamp vignettes/diagnostics.qmd
	quarto render vignettes/diagnostics.qmd --output-dir ../CSF_Spectronaut/all_data/log2/swap  -P subset_dir=CSF_Spectronaut/all_data  -P normalization=log2 -P truth_kind=sample_swap -P truth_path=CSF_Spectronaut/CSF_protein_swap_list.csv -P base_dir=..

CSF_Spectronaut/good_data/log2/swap/diagnostics.html: CSF_Spectronaut/good_data/log2/swap/.stamp vignettes/diagnostics.qmd
	quarto render vignettes/diagnostics.qmd --output-dir ../CSF_Spectronaut/good_data/log2/swap -P subset_dir=CSF_Spectronaut/good_data -P normalization=log2 -P truth_kind=sample_swap -P truth_path=CSF_Spectronaut/CSF_protein_swap_list.csv -P base_dir=..


# --- CSF_Spectronaut_sample_swap diagnostics ---------------------------------
diag-sample-swap: \
    diag-ss-all_data-log2  diag-ss-all_data-median  diag-ss-all_data-quantile \
    diag-ss-good_data-log2 diag-ss-good_data-median diag-ss-good_data-quantile \
    diag-ss-small_good-log2 diag-ss-small_good-median diag-ss-small_good-quantile

diag-ss-all_data-log2:        CSF_Spectronaut_sample_swap/all_data/log2/swap/diagnostics.html
diag-ss-all_data-median:      CSF_Spectronaut_sample_swap/all_data/median/swap/diagnostics.html
diag-ss-all_data-quantile:    CSF_Spectronaut_sample_swap/all_data/quantile/swap/diagnostics.html
diag-ss-good_data-log2:       CSF_Spectronaut_sample_swap/good_data/log2/swap/diagnostics.html
