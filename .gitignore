# Allow files by default; ignore only generated artefacts, binaries, and
# folders we are not actively working on.

# --- OS / editor ---
.DS_Store
.idea/
.vscode/

# --- R ---
.Rhistory
.RData
.Ruserdata
Rplots.pdf
*.Rproj.user/
.runner_tmp/
.quarto/
**/*.quarto_ipynb
**/*_files/
vignettes/*.html
vignettes/*.pdf
!vignettes/*.qmd

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# --- Logs ---
*.log

# --- Archives / large binaries ---
*.tar.gz
*.zip
*.RDS
*.rds
*.rda
*.RData

# --- Spectronaut / DIA raw report TSVs (large) ---
*_Report.tsv
*_report.tsv
*_report_nodecoy.tsv
orig_*_Report.tsv

# --- Current Makefile-generated inputs and outputs ---
**/.prep.stamp
**/Report.tsv
**/annotation.csv
**/all_data/
**/good_data/
**/small_good_data/
CSF_Spectronaut_protein_swap/small/
CSF_Spectronaut_protein_swap/*_swap_ground_truth.tsv
CSF_Spectronaut_protein_swap/*_swap_group_annotation.csv
CSF_Spectronaut_protein_swap/*_swap_true_positives.tsv
CSF_Spectronaut_sample_swap/CSF_annotation.csv
CSF_Spectronaut_sample_swap/CSF_protein_swap_list.csv
CSF_Spectronaut_sample_swap/*_sample_swap_ground_truth.tsv
CSF_Spectronaut_sample_swap/*_sample_swap_group_annotation.csv
CSF_Spectronaut_sample_swap/*_sample_swap_true_positives.tsv

# --- Per-run modelling output folders (generated) ---
**/V1_log2/
**/V1_log/
**/v2_median/
**/v2_vsn/
**/v3_quantile/

# --- Mix_of_Proteome legacy per-package output dirs (will be regenerated under the new layout) ---
Mix_of_Proteome/DEqMS/
Mix_of_Proteome/MSstats/
Mix_of_Proteome/MSstats+/
Mix_of_Proteome/limma/
Mix_of_Proteome/limpa/
Mix_of_Proteome/mapDIA/
Mix_of_Proteome/msqrob2/

# --- Out-of-scope folders (moved to ../../out_of_scope/; ignored defensively) ---
CSF_DIANN/
K562_DIANN/
K562_Spectronaut/
TPCPA/

# --- Test / coverage / Quarto-cache artifacts ---
.coverage
.pytest_cache/
vignettes/*_cache/
